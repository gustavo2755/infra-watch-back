APP_NAME="Infra Watch"
APP_ENV=local
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=infra_watch
DB_USERNAME=infra_watch
DB_PASSWORD=infra_watch

# Usuário criado pelo seed (se não definido, usa admin@infra.watch / password123)
SEED_ADMIN_EMAIL=admin@infra.watch
SEED_ADMIN_PASSWORD=password123

JWT_SECRET=change-this-secret-in-production-min-32-chars

# CORS: origem do frontend (ex: http://localhost:5174) ou * para qualquer origem
CORS_ORIGIN=http://localhost:5174
