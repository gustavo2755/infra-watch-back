{
  "name": "infra-watch/infra-watch",
  "description": "Minimal bootstrap for Infra Watch with Docker, PHP and MySQL.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/"
    },
    "classmap": [
      "database/Migrator.php",
      "database/seeders/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S 0.0.0.0:8000 -t public",
    "test": "phpunit",
    "migrate": "php database/migrate.php",
    "seed": "php database/seed.php"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  }
}
